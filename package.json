{
  "name": "mino_skincare",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "intlayer watch --with next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "openapi:generate:client": "npx @openapitools/openapi-generator-cli generate -g typescript-fetch -i docs/openapi.yaml -o client --additional-properties=typescriptThreePlus=true,supportsES6=true",
    "openapi:generate:server": "npx @openapitools/openapi-generator-cli generate -g nodejs-express-server -i docs/openapi.yaml -o server --additional-properties=usePromises=true,typescriptThreePlus=true",
    "openapi:generate": "pnpm openapi:generate:client",
    "regenerate": "powershell -ExecutionPolicy Bypass -File ./regenerate.ps1"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/bcryptjs": "^3.0.0",
